{
  "info": {
    "name": "Online Course Platform API",
    "description": "Production-grade course platform API collection with full Courses, Sections, and Lessons support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "course_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "section_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "lesson_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "upload_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        },
        {
          "name": "Readiness",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health/ready"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('access_token', res.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"student@test.com\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('access_token', res.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"instructor@test.com\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('access_token', res.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\"refresh_token\": \"{{refresh_token}}\"}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('user_id', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/users/me"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\"bio\": \"I teach Python\", \"expertise\": \"Python, FastAPI\", \"website\": \"https://mysite.com\"}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/users/me/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\"old_password\": \"password123\", \"new_password\": \"newpassword456\"}"
            }
          }
        },
        {
          "name": "Apply for Instructor",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/users/me/instructor-apply"
          }
        },
        {
          "name": "Upload Avatar",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/users/me/avatar",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": ""}
              ]
            }
          }
        },
        {
          "name": "Get Public Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/{{user_id}}/public"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('course_id', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/courses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Advanced FastAPI Mastery\",\n  \"description\": \"Learn how to build production-ready applications with FastAPI, Tortoise ORM, and Docker.\",\n  \"short_description\": \"Complete production-grade course.\",\n  \"price\": 49.99,\n  \"category_id\": null,\n  \"language\": \"English\",\n  \"difficulty\": \"intermediate\"\n}"
            }
          }
        },
        {
          "name": "Get My Courses (Instructor)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/courses/instructor/me"
          }
        },
        {
          "name": "Get Course by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}"
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Advanced FastAPI Mastery (Updated)\",\n  \"price\": 59.99\n}"
            }
          }
        },
        {
          "name": "Publish Course",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/publish"
          }
        },
        {
          "name": "Unpublish Course",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/unpublish"
          }
        },
        {
          "name": "Upload Course Thumbnail",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/thumbnail",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          }
        },
        {
          "name": "Get Course Curriculum",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/curriculum"
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}"
          }
        }
      ]
    },
    {
      "name": "Sections",
      "item": [
        {
          "name": "Create Section",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('section_id', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/sections",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction to FastAPI\"\n}"
            }
          }
        },
        {
          "name": "Update Section",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/sections/{{section_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction to FastAPI (Updated)\",\n  \"position\": 1\n}"
            }
          }
        },
        {
          "name": "Delete Section",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/courses/{{course_id}}/sections/{{section_id}}"
          }
        }
      ]
    },
    {
      "name": "Lessons",
      "item": [
        {
          "name": "Create Lesson",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('lesson_id', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/sections/{{section_id}}/lessons",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Your First API Endpoint\",\n  \"lesson_type\": \"article\",\n  \"article_body\": \"In this lesson, we will write our first async def main()...\",\n  \"is_preview\": true\n}"
            }
          }
        },
        {
          "name": "Update Lesson",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/sections/{{section_id}}/lessons/{{lesson_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Your First API Endpoint (Updated)\",\n  \"is_preview\": false,\n  \"position\": 2\n}"
            }
          }
        },
        {
          "name": "Delete Lesson",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/sections/{{section_id}}/lessons/{{lesson_id}}"
          }
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "Get Upload URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.upload_id) {",
                  "  pm.collectionVariables.set('upload_id', res.upload_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/media/upload-url",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lesson_id\": \"{{lesson_id}}\",\n  \"content_type\": \"video/mp4\"\n}"
            }
          }
        },
        {
          "name": "Confirm Upload",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{base_url}}/api/v1/media/confirm-upload",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"upload_id\": \"{{upload_id}}\"\n}"
            }
          }
        },
        {
          "name": "Get Upload Status",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/media/status/{{upload_id}}"
          }
        }
      ]
    }
  ]
}